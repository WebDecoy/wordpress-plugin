parameters:
    level: 3
    paths:
        - webdecoy.php
        - includes/
        - admin/
        - templates/
    excludePaths:
        - vendor/
    scanDirectories:
        - sdk/src/
    bootstrapFiles:
        - vendor/php-stubs/wordpress-stubs/wordpress-stubs.php
        - vendor/php-stubs/woocommerce-stubs/woocommerce-stubs.php
    ignoreErrors:
        - '#Constant [A-Z_]+ not found#'
