{
    "name": "webdecoy/sdk",
    "description": "PHP SDK for WebDecoy bot detection, spam prevention, and threat intelligence",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "bot-detection",
        "spam-prevention",
        "security",
        "threat-intelligence",
        "carding-protection",
        "web-security",
        "waf"
    ],
    "authors": [
        {
            "name": "WebDecoy",
            "email": "support@webdecoy.com",
            "homepage": "https://webdecoy.com"
        }
    ],
    "homepage": "https://github.com/webdecoy/php-sdk",
    "support": {
        "issues": "https://github.com/webdecoy/php-sdk/issues",
        "docs": "https://docs.webdecoy.com/php-sdk"
    },
    "require": {
        "php": ">=7.4",
        "ext-curl": "*",
        "ext-json": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.0",
        "phpstan/phpstan": "^1.0",
        "squizlabs/php_codesniffer": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "WebDecoy\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "WebDecoy\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "analyse": "phpstan analyse src --level=6",
        "cs": "phpcs --standard=PSR12 src/",
        "cs-fix": "phpcbf --standard=PSR12 src/"
    },
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
