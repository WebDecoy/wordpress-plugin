{
    "name": "webdecoy/wordpress-plugin",
    "description": "WebDecoy Bot Detection WordPress Plugin",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "homepage": "https://webdecoy.com",
    "authors": [
        {
            "name": "WebDecoy",
            "email": "support@webdecoy.com",
            "homepage": "https://webdecoy.com"
        }
    ],
    "support": {
        "issues": "https://github.com/WebDecoy/wordpress-plugin/issues",
        "source": "https://github.com/WebDecoy/wordpress-plugin"
    },
    "keywords": ["wordpress", "security", "bot-detection", "woocommerce", "anti-spam"],
    "require": {
        "php": ">=7.4"
    },
    "require-dev": {
        "squizlabs/php_codesniffer": "^3.7",
        "wp-coding-standards/wpcs": "^3.0",
        "phpcompatibility/phpcompatibility-wp": "^2.1",
        "phpstan/phpstan": "^1.10",
        "szepeviktor/phpstan-wordpress": "^1.3",
        "php-stubs/wordpress-stubs": "^6.4",
        "dealerdirect/phpcodesniffer-composer-installer": "^1.0"
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    }
}
